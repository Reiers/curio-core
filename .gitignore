# Build output
/curio-core
/dist/

# Test/operator data
/data/
*.sqlite
*.sqlite-journal

# Internal-only working notes, strategy docs, competitive analysis, draft
# correspondence, dashboard screenshots. NEVER track these in the public repo.
/internal-notes/

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp

# Auto-synced from upstream Curio module cache by background tooling.
# We intentionally don't track or apply these; the canonical SQLite
# schema lives in internal/harmonysqlite/schema-curio-core/.
internal/harmonysqlite/migrations/
*.bin

# VitePress docs site (docs/) - track sources, ignore build output
docs/node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/
/dist/
